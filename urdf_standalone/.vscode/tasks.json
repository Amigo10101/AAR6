{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake Build",
            "type": "shell",
            "command": "cmake --build \"${workspaceFolder}/build\" --target visualization -j4",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$gcc"
        },
        {
            "label": "CMake Configure",
            "type": "shell",
            "command": "cmake -B build -S .",
            "group": "build"
        },
        {
            "label": "Build Collision Checker",
            "type": "shell",
            "command": "cmake --build \"${workspaceFolder}/build\" --target test_collision_checker -j4",
            "group": "build",
            "problemMatcher": "$gcc"
        },
        {
            "label": "Run Collision Checker",
            "type": "shell",
            "command": "${workspaceFolder}/build/collision_checker/test_collision_checker ${workspaceFolder}/resources/aar6/urdf/aar6.urdf",
            "dependsOn": "Build Collision Checker",
            "group": {
                "kind": "test",
                "isDefault": false
            },
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "label": "Build IK Example",
            "type": "shell",
            "command": "cmake --build \"${workspaceFolder}/build\" --target ik_example -j4",
            "group": "build",
            "problemMatcher": "$gcc"
        }
    ]
}